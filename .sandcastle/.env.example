# Copy this file to `.env` and edit to override defaults. `.env` is
# gitignored — anything you set here stays on your machine.
#
# Sandcastle injects every key declared here into the sandbox at launch.

# --- Auth (pick one) ------------------------------------------------------
#
# Claude subscription (no API key). Generate a long-lived OAuth token on the
# host, then paste it here:
#   claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=
#
# Or use an API key instead:
# ANTHROPIC_API_KEY=

# --- Model ----------------------------------------------------------------
#
# Pin the model sandcastle uses for both `npm run sandcastle` and
# `npm run tasks`. Set to whatever opus / sonnet you want — including
# versions not yet committed-safe to write in tracked code.

# SANDCASTLE_MODEL=claude-opus-4-5
# SANDCASTLE_MODEL=claude-sonnet-4-5

# Optional: override the Docker image name (only matters if you've
# built variants of the agent image).
# SANDCASTLE_IMAGE=redial-sandcastle:local
