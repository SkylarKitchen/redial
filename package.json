{
  "name": "redial",
  "version": "0.1.0",
  "description": "A floating CSS tuning panel for Next.js. Click any element, get context-aware controls, drag to tune, save directly to source.",
  "author": "Skylar Kitchen",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkylarKitchen/redial"
  },
  "homepage": "https://github.com/SkylarKitchen/redial#readme",
  "bugs": {
    "url": "https://github.com/SkylarKitchen/redial/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./next-plugin": {
      "types": "./next-plugin.d.cts",
      "default": "./next-plugin.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.sandcastle.json",
    "test": "vitest run",
    "lint": "eslint src/overlay",
    "test:visual": "bash scripts/visual-test.sh",
    "test:visual:ci": "playwright test",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "sandcastle": "tsx .sandcastle/main.ts",
    "sandcastle:init": "npx @ai-hero/sandcastle init",
    "sandcastle:build-image": "npx @ai-hero/sandcastle docker build-image --image-name redial-sandcastle:local --dockerfile .sandcastle/Dockerfile",
    "sandcastle:merge": "tsx scripts/sandcastle-merge.ts",
    "tasks": "tsx scripts/run-tasks.ts"
  },
  "keywords": [
    "css",
    "tuner",
    "nextjs",
    "devtool",
    "webflow",
    "inspector",
    "design-tool"
  ],
  "files": [
    "dist",
    "!dist/**/*.map",
    "next-plugin.cjs",
    "next-plugin.d.cts",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "motion": "^12.35.2"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.6.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "happy-dom": "^20.8.3",
    "next": "^16.1.6",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.18"
  }
}
